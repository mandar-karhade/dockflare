# Cloudflare API Token
# Create at: https://dash.cloudflare.com/profile/api-tokens
# Required scopes:
#   - Cloudflare Tunnel (Account, Edit)
#   - DNS (Zone, Edit)
#   - Zone (Zone, Read)
#   - Zone Settings (Zone, Read)
#   - Account Settings (Account, Read)
CF_TOKEN=your_cloudflare_api_token_here
